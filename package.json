{
  "name": "golem-cli",
  "version": "0.1.1",
  "description": "Provider-agnostic CLI AI coding assistant",
  "type": "module",
  "bin": {
    "golem": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.*",
    "README.md",
    "README.npm.md",
    "LICENSE",
    "!README.github.bak"
  ],
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai",
    "cli",
    "coding-assistant",
    "llm",
    "terminal"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/google": "^3.0.52",
    "@ai-sdk/mcp": "^1.0.30",
    "@ai-sdk/openai": "^3.0.47",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ai": "^6.0.134",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.0",
    "fast-glob": "^3.3.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "meow": "^13.0.0",
    "ollama-ai-provider": "^1.0.0",
    "react": "^18.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
