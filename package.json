{
  "name": "golem",
  "version": "0.2.0",
  "description": "A modular, provider-agnostic coding agent",
  "type": "module",
  "main": "dist/index.js",
  "imports": {
    "#core/*": "./src/core/*",
    "#adapters/*": "./src/adapters/*",
    "#tools/*": "./src/tools/*",
    "#pipeline/*": "./src/pipeline/*"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "vitest run tests/evals/",
    "eval:real": "GOLEM_EVAL_MODE=real vitest run tests/evals/"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai": "^3.0.48",
    "ai": "^6.0.138",
    "chalk": "^5.4.0",
    "diff": "^7.0.0",
    "ink": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.0.0",
    "ollama-ai-provider": "^1.2.0",
    "react": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "ink-testing-library": "^4.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^1.6.0"
  }
}
