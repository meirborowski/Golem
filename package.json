{
  "name": "golem",
  "version": "0.2.0",
  "description": "A modular, provider-agnostic coding agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/meirborowski/Golem.git"
  },
  "keywords": [
    "coding-agent",
    "ai",
    "cli",
    "llm",
    "vibe-coding",
    "developer-tools"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "dist/index.js",
  "imports": {
    "#core/*": "./src/core/*",
    "#adapters/*": "./src/adapters/*",
    "#tools/*": "./src/tools/*",
    "#pipeline/*": "./src/pipeline/*"
  },
  "scripts": {
    "build": "tsc && tsc-alias && node -e \"require('fs').cpSync('src/agents','dist/agents',{recursive:true})\"",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "eval": "vitest run tests/evals/",
    "eval:real": "GOLEM_EVAL_MODE=real vitest run tests/evals/"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai": "^3.0.48",
    "ai": "^6.0.138",
    "chalk": "^5.4.0",
    "diff": "^7.0.0",
    "ink": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.0.0",
    "ollama-ai-provider": "^1.2.0",
    "react": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/diff": "^7.0.0",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^1.6.0"
  }
}
