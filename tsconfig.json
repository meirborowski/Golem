{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "paths": {
      "#core/*": ["./src/core/*"],
      "#adapters/*": ["./src/adapters/*"],
      "#tools/*": ["./src/tools/*"],
      "#pipeline/*": ["./src/pipeline/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "tests"]
}
